# First Look — Environment Variables
# Copy this file to .env and fill in your values.

# ── Supabase ──────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Leave both blank to use local storage (IndexedDB) fallback for dev.

# ── Stripe (payments) ────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
